# ===========================================
# UAP Disclosure Tracker — Environment Config
# ===========================================
# Copy this file to .env and fill in your values

# Database (PostgreSQL on Digital Ocean)
DATABASE_URL="postgresql://username:password@localhost:5432/uap_tracker?schema=public"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-here"

# Claude API (Anthropic) — for AI document summaries
ANTHROPIC_API_KEY="sk-ant-your-key-here"

# Firebase (Push Notifications) — optional for MVP
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
FIREBASE_SERVICE_ACCOUNT_KEY=""

# App Config
NEXT_PUBLIC_APP_NAME="UAP Disclosure Tracker"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# YouTube Data API v3 (FREE — 10,000 quota units/day)
# Get key: https://console.cloud.google.com → Enable YouTube Data API v3 → Create API Key
YOUTUBE_API_KEY="your-youtube-api-key-here"

# Scraper Config (how often to check sources, in minutes)
SCRAPER_INTERVAL_MINUTES=60
